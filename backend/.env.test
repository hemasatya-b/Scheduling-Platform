# Used only by the test suite (vitest). Points at a separate database on the
# same local Postgres instance so tests never touch dev/seed data.
DATABASE_URL="postgresql://scheduling:scheduling@localhost:5433/scheduling_platform_test?schema=public"
DIRECT_URL="postgresql://scheduling:scheduling@localhost:5433/scheduling_platform_test?schema=public"

PORT=5001
NODE_ENV=test
FRONTEND_URL="http://localhost:3000"

# Fixed UUID used as the seeded host user for every test run.
DEFAULT_USER_ID="11111111-1111-1111-1111-111111111111"
