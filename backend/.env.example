# PostgreSQL connection string (matches root docker-compose.yaml defaults).
# In production, set this to your Supabase pooled connection string
# (port 6543, Supavisor/PgBouncer, with ?pgbouncer=true).
DATABASE_URL="postgresql://scheduling:scheduling@localhost:5433/scheduling_platform?schema=public"

# Direct (non-pooled) connection used by `prisma migrate`. Locally this is
# the same database; in production, use Supabase's direct connection string
# (port 5432).
DIRECT_URL="postgresql://scheduling:scheduling@localhost:5433/scheduling_platform?schema=public"

# Server
PORT=5000
NODE_ENV=development

# CORS — origin allowed to call this API
FRONTEND_URL="http://localhost:3000"

# Single-tenant v1: the seeded host user (see prisma/seed.ts)
DEFAULT_USER_ID="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
