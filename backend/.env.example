# PostgreSQL connection string (matches root docker-compose.yaml defaults)
DATABASE_URL="postgresql://scheduling:scheduling@localhost:5433/scheduling_platform?schema=public"

# Server
PORT=5000
NODE_ENV=development

# CORS — origin allowed to call this API
FRONTEND_URL="http://localhost:3000"

# Single-tenant v1: the seeded host user (see prisma/seed.ts)
DEFAULT_USER_ID="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
